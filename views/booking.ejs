<!DOCTYPE html>
<html lang="<%= locale %>" data-theme="dark" dir="<%= locale === 'ar' ? 'rtl' : 'ltr' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= (typeof t === 'function' ? t('intro.title') : 'LUXERIDE') %></title>
  <meta name="description" content="Experience luxury travel with LUXERIDE. Premium chauffeur services with transparent pricing, professional drivers, and exclusive vehicles." />
  <meta name="keywords" content="luxury chauffeur,premium transportation,airport transfer,executive ride,bahrain" />
  <meta name="robots" content="index,follow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;500;600&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css" />
</head>
<body>
  <!-- Global Alert/Notification System -->
  <div id="alert-container" class="alert-container" role="region" aria-live="polite" aria-atomic="true"></div>

  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="brand" id="brand-name">LUXE<span>RIDE</span></a>
      <nav class="header-nav">
        <a href="#booking"><%= t('nav.book') %></a>
        <a href="#track-booking"><%= t('nav.track') %></a>
        <a href="/contact"><%= t('nav.contact') %></a>
      </nav>
      <div class="header-tools">
        <select class="chip-btn" id="currency-toggle" type="button">
          <option value="BHD" data-i18n="currency.bhd">BHD</option>
          <option value="AED" data-i18n="currency.aed">AED</option>
          <option value="SAR" data-i18n="currency.sar">SAR</option>
          <option value="QAR" data-i18n="currency.qar">QAR</option>
          <option value="OMR" data-i18n="currency.omr">OMR</option>
          <option value="KWD" data-i18n="currency.kwd">KWD</option>
          <option value="USD" data-i18n="currency.usd">USD</option>
        </select>
        <button class="chip-btn" id="lang-toggle" type="button">AR</button>
        <button class="chip-btn" id="theme-toggle" type="button" data-i18n="theme.switchToLight">Light</button>
      </div>
    </div>
  </header>

  <main id="booking" class="booking-shell">
    <section id="system-banner" class="warn hidden"></section>

    <section class="booking-intro">
      <p class="eyebrow" data-i18n="intro.subtitle">Premium Luxury Transportation</p>
      <p id="enhance-cta" class="enhance-cta hidden">Enhance Your Journey</p>
      <h1 data-i18n="intro.title">Move in Silence & Style</h1>
      <p data-i18n="intro.description">Experience premium chauffeur services with transparent pricing, professional drivers, and exclusive vehicles designed for your comfort.</p>
    </section>

    <section class="booking-card">
      <div class="stepper" aria-label="Booking steps">
        <div class="step active" data-step="1"><span>1</span><span data-i18n="steps.trip">Trip</span></div>
        <div class="line"></div>
        <div class="step" data-step="2"><span>2</span><span data-i18n="steps.vehicle">Vehicle</span></div>
        <div class="line"></div>
        <div class="step" data-step="3"><span>3</span><span data-i18n="steps.details">Details</span></div>
        <div class="line"></div>
        <div class="step" data-step="4"><span>4</span><span data-i18n="steps.confirm">Confirm</span></div>
      </div>

      <section class="form-step" id="step-1">
        <h2 data-i18n="sections.tripDetails">Trip Details</h2>
        <div class="service-tabs">
          <button class="service-btn active" data-service="trip" type="button" data-i18n="service.transfer">Transfer</button>
          <button class="service-btn" data-service="hourly" type="button" data-i18n="service.hourly">Hourly</button>
        </div>

        <div id="trip-panel" class="service-panel active">
          <div class="toggle-row">
            <label><input type="radio" name="transferType" value="oneway" checked /> <span data-i18n="trip.oneWay">One Way</span></label>
            <label><input type="radio" name="transferType" value="roundtrip" /> <span data-i18n="trip.roundTrip">Round Trip</span></label>
          </div>

          <div class="grid-2">
            <label class="field full"><span data-i18n="fields.pickup">Pickup Location</span>
              <input id="pickup-location" type="text" data-i18n-placeholder="placeholders.pickup" placeholder="Bahrain International Airport" required />
              <ul class="geo-list" id="pickup-suggestions"></ul>
            </label>
            <label class="field full"><span data-i18n="fields.dropoff">Dropoff Location</span>
              <input id="dropoff-location" type="text" data-i18n-placeholder="placeholders.dropoff" placeholder="Seef District, Manama" required />
              <ul class="geo-list" id="dropoff-suggestions"></ul>
            </label>
            <p class="subtext" data-i18n="trip.locationHint">Select locations from the suggestion list to ensure accurate routing.</p>
            <div class="field full field-inline">
              <label class="inline-item"><span data-i18n="fields.departureDate">Departure Date</span><input id="departure-date" type="date" required /></label>
              <label class="inline-item"><span data-i18n="fields.departureTime">Departure Time</span><input id="departure-time" type="time" required /></label>
            </div>
            <div class="field full return-only hidden field-inline">
              <label class="inline-item"><span data-i18n="fields.returnDate">Return Date</span><input id="return-date" type="date" /></label>
              <label class="inline-item"><span data-i18n="fields.returnTime">Return Time</span><input id="return-time" type="time" /></label>
            </div>
            <label class="field"><span data-i18n="fields.passengers">Passengers</span>
              <select id="passengers" required>
                <option value="" data-i18n="common.select">Select</option>
                <option value="1">1</option>
                <option value="2">2</option>
                <option value="3">3</option>
                <option value="4">4</option>
                <option value="5">5</option>
                <option value="6">6</option>
                <option value="7">7</option>
                <option value="8">8</option>
              </select>
            </label>
            <label class="field"><span data-i18n="fields.luggage">Luggage</span>
              <select id="luggage">
                <option value="0">0</option>
                <option value="1">1</option>
                <option value="2">2</option>
                <option value="3">3</option>
                <option value="4">4+</option>
              </select>
            </label>
            <label class="field full"><span data-i18n="fields.flightNumber">Flight Number</span><input id="flight-number" type="text" data-i18n-placeholder="placeholders.flight" placeholder="GF 123" /></label>
          </div>
        </div>

        <div id="hourly-panel" class="service-panel">
          <div class="grid-2">
            <label class="field full"><span data-i18n="fields.pickup">Pickup Location</span>
              <input id="hourly-pickup" type="text" data-i18n-placeholder="placeholders.hourlyPickup" placeholder="Manama City Centre" />
              <ul class="geo-list" id="hourly-suggestions"></ul>
            </label>
            <label class="field"><span data-i18n="fields.date">Date</span><input id="hourly-date" type="date" /></label>
            <label class="field"><span data-i18n="fields.startTime">Start Time</span><input id="hourly-time" type="time" /></label>
            <label class="field"><span data-i18n="fields.duration">Duration</span>
              <select id="hourly-duration">
                <option value="" data-i18n="common.select">Select</option>
                <option value="2">2 Hours</option>
                <option value="3">3 Hours</option>
                <option value="4">4 Hours</option>
                <option value="5">5 Hours</option>
                <option value="6">6 Hours</option>
                <option value="8">8 Hours</option>
                <option value="10">10 Hours</option>
                <option value="12">12 Hours</option>
              </select>
            </label>
            <label class="field"><span data-i18n="fields.passengers">Passengers</span>
              <select id="hourly-passengers">
                <option value="" data-i18n="common.select">Select</option>
                <option value="1">1</option>
                <option value="2">2</option>
                <option value="3">3</option>
                <option value="4">4</option>
                <option value="5">5</option>
                <option value="6">6</option>
                <option value="7">7</option>
                <option value="8">8</option>
              </select>
            </label>
          </div>
        </div>

        <section class="addons-card">
          <h3 data-i18n="addons.title">Optional Add-ons</h3>
          <div class="addons-grid">
            <label class="addon-item">
              <input id="addon-child-seat" type="checkbox" />
              <span data-i18n="addons.childSeat">Child seat</span>
            </label>
            <label class="field compact"><span data-i18n="addons.childSeatCount">Child seats</span>
              <select id="addon-child-seat-count">
                <option value="0">0</option>
                <option value="1">1</option>
                <option value="2">2</option>
                <option value="3">3</option>
                <option value="4">4</option>
              </select>
            </label>

            <label class="addon-item">
              <input id="addon-extra-luggage" type="checkbox" />
              <span data-i18n="addons.extraLuggage">Extra luggage handling</span>
            </label>
            <label class="field compact"><span data-i18n="addons.extraLuggageCount">Extra luggage pieces</span>
              <select id="addon-extra-luggage-count">
                <option value="0">0</option>
                <option value="1">1</option>
                <option value="2">2</option>
                <option value="3">3</option>
                <option value="4">4</option>
                <option value="5">5</option>
                <option value="6">6</option>
                <option value="7">7</option>
                <option value="8">8</option>
              </select>
            </label>

            <label class="addon-item full">
              <input id="addon-pet-friendly" type="checkbox" />
              <span data-i18n="addons.petFriendly">Pet-friendly trip setup</span>
            </label>
          </div>
          <p class="subtext" data-i18n="addons.note">Add-ons are reflected instantly in your live quote.</p>
        </section>

        <div class="actions right"><button class="btn gold" type="button" data-next="2" data-i18n="actions.continue">Continue</button></div>
      </section>

      <section class="form-step hidden" id="step-2">
        <h2 id="fleet" data-i18n="sections.chooseVehicle">Choose Vehicle</h2>
        <p class="subtext" data-i18n="sections.vehicleHelp">Select from our premium fleet.</p>
        <div id="vehicle-grid" class="vehicle-grid"></div>
        <p id="vehicle-warning" class="warn hidden" data-i18n="messages.capacityWarning">Selected vehicle may not fit passenger count.</p>
        <div class="actions">
          <button class="btn" type="button" data-prev="1" data-i18n="actions.back">Back</button>
          <button class="btn gold" type="button" data-next="3" data-i18n="actions.continue">Continue</button>
        </div>
      </section>

      <section class="form-step hidden" id="step-3">
        <h2 data-i18n="sections.contactDetails">Contact Details</h2>
        <div class="grid-2">
          <label class="field"><span data-i18n="fields.firstName">First Name</span><input id="first-name" type="text" required /></label>
          <label class="field"><span data-i18n="fields.lastName">Last Name</span><input id="last-name" type="text" required /></label>
          <label class="field full"><span data-i18n="fields.email">Email</span><input id="email" type="email" required /></label>
          <label class="field"><span data-i18n="fields.countryCode">Country Code</span>
            <select id="country-code">
              <option value="+973">+973 (BH)</option>
              <option value="+966">+966 (SA)</option>
              <option value="+971">+971 (AE)</option>
              <option value="+974">+974 (QA)</option>
              <option value="+965">+965 (KW)</option>
              <option value="+968">+968 (OM)</option>
            </select>
          </label>
          <label class="field"><span data-i18n="fields.phone">Phone</span><input id="phone" type="tel" required /></label>
          <label class="field full"><span data-i18n="fields.specialRequests">Special Requests</span><textarea id="special-requests" rows="3"></textarea></label>
        </div>
        <div class="actions">
          <button class="btn" type="button" data-prev="2" data-i18n="actions.back">Back</button>
          <button class="btn gold" type="button" data-next="4" data-i18n="actions.review">Review</button>
        </div>
      </section>

      <section class="form-step hidden" id="step-4">
        <h2 data-i18n="sections.confirmBooking">Confirm Booking</h2>
        <p id="quote-loading" class="subtext hidden" data-i18n="messages.quoteLoading">Calculating latest quote...</p>
        <div class="summary" id="summary-box"></div>
        <div id="recommendations-box" class="recommendations hidden"></div>
        <div class="promo-row">
          <label class="field promo-field"><span data-i18n="fields.promoCode">Promo Code</span>
            <input id="promo-code" type="text" data-i18n-placeholder="placeholders.promo" placeholder="WELCOME10" />
          </label>
          <div class="promo-actions">
            <button class="btn" id="apply-promo-btn" type="button" data-i18n="actions.apply">Apply</button>
            <button class="btn" id="remove-promo-btn" type="button" data-i18n="actions.remove">Remove</button>
          </div>
        </div>
        <p id="promo-message" class="subtext"></p>
        <div class="confirm-row">
          <label><input id="terms" type="checkbox" /> <span data-i18n="fields.terms">I agree to terms and privacy policy</span></label>
          <strong id="price-preview">BHD 0.000</strong>
        </div>
        <div class="actions">
          <button class="btn" type="button" data-prev="3" data-i18n="actions.back">Back</button>
          <button class="btn gold" id="submit-btn" type="button" data-i18n="actions.confirmBooking">Confirm Booking</button>
        </div>
        <p id="form-message"></p>
      </section>

      <section class="form-step hidden" id="step-5">
        <div class="success">
          <h2 data-i18n="sections.bookingSubmitted">Booking Submitted</h2>
          <p data-i18n="messages.bookingReceived">Your request has been received. We will contact you soon.</p>
          <p><span data-i18n="messages.reference">Reference</span>: <strong id="booking-ref"></strong></p>
          <button class="btn gold" id="new-booking-btn" type="button" data-i18n="actions.newBooking">Create New Booking</button>
        </div>
      </section>
    </section>
  </main>

  <section class="track-shell" id="track-booking">
    <div class="track-card">
      <h2 data-i18n="tracking.title">Track My Booking</h2>
      <p class="subtext" data-i18n="tracking.subtitle">Use your booking reference and email to view status and trip details.</p>
      <form id="track-form" class="grid-2">
        <label class="field"><span data-i18n="tracking.reference">Booking Reference</span><input id="track-ref" required placeholder="LXR-ABC123" /></label>
        <label class="field"><span data-i18n="tracking.email">Email</span><input id="track-email" type="email" required placeholder="you@example.com" /></label>
        <div class="actions"><button class="btn gold" type="submit" data-i18n="tracking.track">Track Booking</button></div>
      </form>
      <div id="track-result" class="track-result hidden"></div>
    </div>
  </section>

  <div id="cancel-modal" class="modal hidden" role="dialog" aria-modal="true" aria-labelledby="cancel-modal-title">
    <div class="modal-card">
      <h3 id="cancel-modal-title" data-i18n="tracking.cancelTitle">Cancel Booking?</h3>
      <p data-i18n="tracking.cancelText">This action cannot be undone. Only pending or confirmed bookings can be cancelled.</p>
      <div class="actions">
        <button class="btn" type="button" id="cancel-modal-close" data-i18n="tracking.keep">Keep Booking</button>
        <button class="btn gold" type="button" id="cancel-confirm-btn" data-i18n="tracking.confirmCancel">Confirm Cancellation</button>
      </div>
    </div>
  </div>

  <a id="whatsapp-fab" class="whatsapp-fab hidden" href="#" target="_blank" rel="noopener" data-i18n="tracking.whatsapp">WhatsApp</a>

  <section id="service" class="service-strip">
    <div data-i18n="benefits.dispatch">24/7 Dispatch</div>
    <div data-i18n="benefits.chauffeurs">Professional Chauffeurs</div>
    <div data-i18n="benefits.business">Business & Leisure</div>
    <div data-i18n="benefits.transparent">Transparent Pricing</div>
  </section>

  <footer class="app-footer">
    <div class="footer-inner">
      <p>© <span id="footer-year"></span> <span id="footer-brand">LUXERIDE</span>. <span data-i18n="footer.rights">All rights reserved.</span></p>
      <p id="footer-contact" data-i18n="footer.defaultContact">Premium chauffeur experiences in the Gulf.</p>
    </div>
  </footer>

  <script src="/js/app.js" defer></script>
  <script src="/js/ui.js" defer></script>
</body>
</html>
