<% const skipTarget = typeof skipLinkTarget === 'string' ? skipLinkTarget : '#main'; %>
<% const bookUrl = typeof bookHref === 'string' ? bookHref : '#main'; %>
<% const trackUrl = typeof trackHref === 'string' ? trackHref : '#track-booking'; %>
<% const contactUrl = typeof contactHref === 'string' ? contactHref : '/contact'; %>
<% if (showSkipLink) { %>
  <a href="<%= skipTarget %>" class="skip-link">Skip to content</a>
<% } %>
<% if (showAlertContainer) { %>
  <div id="alert-container" class="alert-container" role="region" aria-live="polite" aria-atomic="true"></div>
<% } %>
<header class="site-header">
  <div class="header-inner">
    <a href="/" class="brand" id="brand-name">LUXE<span>RIDE</span></a>
    <button class="nav-toggle" id="nav-toggle" type="button" aria-label="Toggle navigation" aria-expanded="false" aria-controls="primary-nav">☰</button>
    <nav class="header-nav" id="primary-nav">
      <a href="<%= bookUrl %>" data-i18n="nav.book">Book</a>
      <a href="<%= trackUrl %>" data-i18n="nav.track">Track My Booking</a>
      <a href="<%= contactUrl %>" data-i18n="nav.contact">Contact Us</a>
    </nav>
    <div class="header-tools">
      <select class="chip-btn" id="currency-toggle" type="button">
        <option value="BHD" data-i18n="currency.bhd">¤ BHD</option>
        <option value="AED" data-i18n="currency.aed">¤ AED</option>
        <option value="SAR" data-i18n="currency.sar">¤ SAR</option>
        <option value="QAR" data-i18n="currency.qar">¤ QAR</option>
        <option value="OMR" data-i18n="currency.omr">¤ OMR</option>
        <option value="KWD" data-i18n="currency.kwd">¤ KWD</option>
        <option value="USD" data-i18n="currency.usd">¤ USD</option>
      </select>
      <button class="chip-btn" id="lang-toggle" type="button">🌐 AR</button>
      <button class="chip-btn" id="theme-toggle" type="button" data-i18n="theme.switchToLight">☀ Light</button>
    </div>
  </div>
</header>
