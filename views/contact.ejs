<!DOCTYPE html>
<html lang="<%= locale %>" dir="<%= locale === 'ar' ? 'rtl' : 'ltr' %>">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle || ((typeof t === 'function' ? t('contact.title') : 'Contact Us') + ' | LUXERIDE') %></title>
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
  <script nonce="<%= cspNonce %>">
    (function () {
      var savedTheme = localStorage.getItem('chauffeur_theme');
      if (!savedTheme) {
        savedTheme = window.matchMedia && window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
      }
      document.documentElement.setAttribute('data-theme', savedTheme);
    })();
  </script>
  <link rel="stylesheet" href="/css/style.css?v=20260408" />
</head>
<body>
  <%- include('partials/public-header', {
    showSkipLink: false,
    showAlertContainer: false,
    bookHref: '/',
    trackHref: '/booking#track-booking',
    contactHref: '/contact'
  }) %>

  <main class="booking-shell contact-shell">
    <section class="booking-intro">
      <p class="eyebrow">LUXERIDE</p>
      <h1 data-i18n="contact.title"><%= typeof t === 'function' ? t('contact.title') : 'Contact Us' %></h1>
      <p data-i18n="contact.subtitle"><%= typeof t === 'function' ? t('contact.subtitle') : 'Questions, partnerships or special requests — we’re here to help.' %></p>
    </section>

    <section class="booking-card contact-card">
      <h1 data-i18n="contact.title"><%= typeof t === 'function' ? t('contact.title') : 'Contact Us' %></h1>
      <p class="subtext" data-i18n="contact.subtitle"><%= typeof t === 'function' ? t('contact.subtitle') : 'Questions, partnerships or special requests — we’re here to help.' %></p>

      <form id="contact-form" class="grid-2">
        <label class="field"><span data-i18n="fields.firstName">First Name</span><input id="contact-first" type="text" required /></label>
        <label class="field"><span data-i18n="fields.lastName">Last Name</span><input id="contact-last" type="text" required /></label>
        <label class="field full"><span data-i18n="fields.email">Email</span><input id="contact-email" type="email" required /></label>
        <label class="field"><span data-i18n="fields.countryCode">Country Code</span>
          <select id="country-code">
            <option value="+973">+973 (BH)</option>
            <option value="+966">+966 (SA)</option>
            <option value="+971">+971 (AE)</option>
            <option value="+974">+974 (QA)</option>
            <option value="+965">+965 (KW)</option>
            <option value="+968">+968 (OM)</option>
          </select>
        </label>
        <label class="field"><span data-i18n="fields.phone">Phone</span><input id="contact-phone" type="tel" required /></label>
        <label class="field full"><span data-i18n="contact.message"><%= typeof t === 'function' ? t('contact.message') : 'Message' %></span><textarea id="contact-message-text" rows="6" required></textarea></label>

        <div class="actions">
          <button class="btn gold" type="submit" id="contact-submit" data-i18n="contact.send"><%= typeof t === 'function' ? t('contact.send') : 'Send Message' %></button>
        </div>
        <p id="contact-message" class="subtext" role="status" aria-live="polite"></p>
      </form>
    </section>
  </main>

  <%- include('partials/public-footer') %>

  <script src="/js/contact.js?v=20260408" defer></script>
  <script src="/js/ui.js?v=20260408" defer></script>
</body>
</html>
