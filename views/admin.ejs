<!DOCTYPE html>
<html lang="<%= locale || 'en' %>" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= pageTitle || 'LUXERIDE Admin Control Center' %></title>
  <link rel="icon" type="image/svg+xml" href="/assets/favicon.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@500;600&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/css/style.css?v=20260408" />
  <link rel="stylesheet" href="/css/admin.css?v=20260408" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js" defer crossorigin="anonymous"></script>
</head>
<body class="admin-auth-locked">
  <div class="admin-layout" id="admin-layout">
    <aside class="admin-side" id="admin-side">
      <h1 id="admin-brand-name">LUXERIDE <span>ADMIN</span></h1>
      <p id="admin-brand-tagline">Dispatch Console</p>
      <button class="tab-btn active" data-tab="dashboard">Dashboard</button>
      <button class="tab-btn" data-tab="bookings">Bookings</button>
      <button class="tab-btn" data-tab="chauffeurs">Chauffeurs</button>
      <button class="tab-btn" data-tab="vehicles">Vehicles</button>
      <button class="tab-btn" data-tab="promos">Promos</button>
      <button class="tab-btn" data-tab="users">Users</button>
      <button class="tab-btn" data-tab="pricing">Pricing</button>
      <button class="tab-btn" data-tab="settings">Settings</button>
    </aside>

    <main class="admin-main">
      <section class="login-card" id="login-card">
        <h2>Secure Login</h2>
        <form id="login-form" class="form-grid">
          <label>Email<input name="email" type="email" required /></label>
          <label>Password<input name="password" type="password" required /></label>
          <button type="submit">Login</button>
        </form>
        <p id="login-message"></p>
      </section>

      <section id="app-shell" hidden>
      <%- include('partials/admin-topbar') %>
      <div id="admin-alert-container" class="alert-container" role="region" aria-live="polite" aria-atomic="true"></div>

        <section class="tab-content active" id="tab-dashboard">
          <div class="kpi-grid">
            <article><h3>Total Bookings</h3><strong id="kpi-total">0</strong></article>
            <article><h3>Pending</h3><strong id="kpi-pending">0</strong></article>
            <article><h3>Confirmed</h3><strong id="kpi-confirmed">0</strong></article>
            <article><h3>Completed Trips</h3><strong id="kpi-completed">0</strong></article>
            <article><h3>Revenue</h3><strong id="kpi-revenue">BHD 0.000</strong></article>
            <article><h3>This Month Revenue</h3><strong id="kpi-month-revenue">BHD 0.000</strong></article>
            <article><h3>Average Booking Value</h3><strong id="kpi-avg-value">BHD 0.000</strong></article>
            <article><h3>Today</h3><strong id="kpi-today">0</strong></article>
          </div>
          <div class="analytics-grid">
            <div class="chart-box">
              <h3>Bookings (Last 14 Days)</h3>
              <canvas id="bookings-chart"></canvas>
            </div>
            <div class="chart-box">
              <h3>Revenue (Last 7 Days)</h3>
              <canvas id="revenue-chart"></canvas>
            </div>
          </div>
        </section>

        <section class="tab-content" id="tab-bookings">
          <div class="bookings-workspace">
            <!-- Left: bookings list pane (sticky filters + scrollable list) -->
            <aside class="bookings-list-pane bookings-list" role="region" aria-label="Bookings list">
              <div class="filters sticky-filters">
                <input id="search-bookings" placeholder="Search ref/name/email" />
                <select id="status-filter">
                  <option value="">All statuses</option>
                  <option value="pending">pending</option>
                  <option value="confirmed">confirmed</option>
                  <option value="chauffeur_assigned">chauffeur_assigned</option>
                  <option value="in_progress">in_progress</option>
                  <option value="completed">completed</option>
                  <option value="cancelled">cancelled</option>
                  <option value="rejected">rejected</option>
                </select>
              </div>

              <div class="table-wrap compact" aria-live="polite">
                <table class="compact-table">
                  <thead>
                    <tr>
                      <th>Ref</th>
                      <th>Name</th>
                      <th>Service</th>
                      <th>Pickup</th>
                      <th>Date</th>
                      <th>Price</th>
                      <th>Status</th>
                      <th></th>
                    </tr>
                  </thead>
                  <tbody id="bookings-body"></tbody>
                </table>
              </div>
            </aside>

            <!-- Right: booking detail pane (master-detail) -->
            <aside class="booking-detail-pane" id="booking-detail-pane" role="region" aria-label="Booking details">
              <div class="detail-empty" id="detail-empty">
                <div style="font-size:46px;color:rgba(193,162,90,0.9)">🚘</div>
                <h3>Select a booking to view details</h3>
                <p class="muted">Select any booking on the left to view operations, assignments, and notes here.</p>
              </div>

              <article id="booking-detail" class="detail-panel" hidden>
                <div class="detail-head">
                  <div style="display:flex;align-items:center;gap:0.6rem">
                    <h3>Booking Details</h3>
                    <button id="booking-detail-close" class="btn-secondary mobile-only">Close</button>
                  </div>
                  <div class="detail-head-actions">
                    <button id="print-invoice-btn" class="btn-secondary">Print Invoice</button>
                  </div>
                </div>
                <div id="booking-detail-body" class="detail-groups"></div>
                <div class="detail-sticky-actions" id="booking-actions"></div>
              </article>
            </aside>
          </div>
        </section>

        <section class="tab-content" id="tab-chauffeurs">
          <div class="section-head">
            <div>
              <h3>Chauffeurs</h3>
              <p>Manage drivers and assignments</p>
            </div>
            <button type="button" class="btn-primary" data-open-modal="chauffeur-modal">Add Chauffeur</button>
          </div>
          <div class="filters">
            <input id="search-chauffeurs" placeholder="Search name/phone/email" />
          </div>
          <div class="list-panel" id="chauffeur-list"></div>
        </section>

        <section class="tab-content" id="tab-vehicles">
          <div class="section-head">
            <div>
              <h3>Vehicles</h3>
              <p>Manage fleet and availability</p>
            </div>
            <button type="button" class="btn-primary" data-open-modal="vehicle-modal">Add Vehicle</button>
          </div>
          <div class="list-panel" id="vehicle-list"></div>
        </section>

        <section class="tab-content" id="tab-promos">
          <div class="section-head">
            <div>
              <h3>Promotions</h3>
              <p>Manage discount codes</p>
            </div>
            <button type="button" class="btn-primary" data-open-modal="promo-modal">Add Promo</button>
          </div>
          <div class="list-panel" id="promo-list"></div>
        </section>

        <section class="tab-content" id="tab-users">
          <div class="section-head">
            <div>
              <h3>Users</h3>
              <p>Manage admin and operator accounts</p>
            </div>
            <button type="button" class="btn-primary" data-open-modal="user-modal">Add User</button>
          </div>
          <div class="list-panel" id="user-list"></div>
        </section>
        <section class="tab-content" id="tab-settings">
          <div class="split">
            <form id="settings-form" class="form-panel">
              <h3>App Settings</h3>
              <label>App Name<input name="app_name" required /></label>
              <label>App Tagline<input name="app_tagline" /></label>
              <label>Hero Title<input name="hero_title" /></label>
              <label>Hero Subtitle<textarea name="hero_subtitle" rows="3"></textarea></label>
              <label>Currency Code<input name="currency_code" maxlength="6" /></label>
              <label>Primary Color<input name="primary_color" type="color" /></label>
              <label>Secondary Color<input name="secondary_color" type="color" /></label>
              <label>Support Email<input name="support_email" type="email" /></label>
              <label>Support Phone<input name="support_phone" /></label>
              <label>WhatsApp Number<input name="whatsapp_number" /></label>
              <label>Enhance Your Journey
                <select name="enhance_journey_enabled">
                  <option value="true">true</option>
                  <option value="false">false</option>
                </select>
              </label>
              <label>Enhance Text<input name="enhance_journey_text" /></label>
              <label>Enable Add-ons
                <select name="addons_enabled">
                  <option value="true">true</option>
                  <option value="false">false</option>
                </select>
              </label>
              <label>Maintenance Mode
                <select name="maintenance_mode">
                  <option value="false">false</option>
                  <option value="true">true</option>
                </select>
              </label>
              <label>Booking Enabled
                <select name="booking_enabled">
                  <option value="true">true</option>
                  <option value="false">false</option>
                </select>
              </label>
              <button type="submit">Save App Settings</button>
              <p id="settings-message"></p>
            </form>

            <form id="seo-form" class="form-panel">
              <h3>SEO Settings</h3>
              <label>SEO Title<input name="seo_title" /></label>
              <label>SEO Description<textarea name="seo_description" rows="3"></textarea></label>
              <label>SEO Keywords<input name="seo_keywords" placeholder="comma,separated,keywords" /></label>
              <label>Indexable
                <select name="seo_indexable">
                  <option value="true">true</option>
                  <option value="false">false</option>
                </select>
              </label>
              <label>Instagram<input name="instagram" /></label>
              <label>X / Twitter<input name="x" /></label>
              <label>Facebook<input name="facebook" /></label>
              <label>LinkedIn<input name="linkedin" /></label>
              <button type="submit">Save SEO & Social</button>
            </form>
          </div>
          <div class="split">
            <div class="form-panel">
              <h3>General settings are on the left. Use the Pricing tab to manage fixed fares.</h3>
              <p class="muted">Fixed area pricing now has its own dedicated section for better discoverability.</p>
            </div>
          </div>
        </section>

        <section class="tab-content" id="tab-pricing">
          <div class="split">
            <section id="fixed-pricing-panel" class="form-panel">
              <h3>Fixed Area Pricing</h3>
              <p class="muted">Define origin → destination fixed fares per vehicle category. Use simple substrings (e.g., "bahrain", "dammam airport").</p>

              <div id="fixed-pricing-list" style="margin-bottom:12px">
                <!-- Filled by admin.js -->
              </div>

              <form id="fixed-pricing-form">
                <input type="hidden" name="idx" />
                <label>Origin pattern<input name="origin" placeholder="e.g. bahrain or manama" /></label>
                <label>Destination pattern<input name="destination" placeholder="e.g. dammam or dammam airport" /></label>

                <div style="display:flex;gap:8px;flex-wrap:wrap">
                  <label style="flex:1">Economy Price (BHD)<input name="price_economy" type="number" step="0.001" min="0" placeholder="0.000" /></label>
                  <label style="flex:1">Business Price (BHD)<input name="price_business" type="number" step="0.001" min="0" placeholder="0.000" /></label>
                  <label style="flex:1">SUV Price (BHD)<input name="price_suv" type="number" step="0.001" min="0" placeholder="0.000" /></label>
                  <label style="flex:1">Van Price (BHD)<input name="price_van" type="number" step="0.001" min="0" placeholder="0.000" /></label>
                </div>

                <details id="vehicle-prices-collapse" style="margin-top:8px" class="muted">
                  <summary style="cursor:pointer">Per-vehicle prices (optional) — set a fixed price for specific vehicles</summary>
                  <div id="vehicle-prices-list" style="margin-top:8px;display:flex;flex-direction:column;gap:6px">
                    <!-- populated by admin.js with inputs for each vehicle -->
                  </div>
                </details>

                <label>Active
                  <select name="active">
                    <option value="true">true</option>
                    <option value="false">false</option>
                  </select>
                </label>
                <label>Note<input name="note" placeholder="Optional note shown to users" /></label>
                <label>Priority<input name="priority" type="number" min="0" placeholder="0" /></label>
                <div style="display:flex;gap:8px;margin-top:8px">
                  <button type="submit" class="btn">Save Rule</button>
                  <button type="button" id="fixed-pricing-reset" class="btn">Reset</button>
                </div>
              </form>
            </section>
          </div>
        </section>
      </section>

      <%- include('partials/admin-footer') %>
      <!-- Chauffeur Modal -->
      <div class="admin-modal hidden" id="chauffeur-modal" role="dialog" aria-modal="true" aria-labelledby="chauffeur-modal-title">
        <div class="admin-modal-backdrop" data-close-modal></div>
        <div class="admin-modal-panel">
          <div class="admin-modal-head">
            <h3 id="chauffeur-modal-title">Create Chauffeur</h3>
            <button type="button" class="icon-btn" data-close-modal aria-label="Close modal">×</button>
          </div>
          <div class="admin-modal-body">
            <form id="chauffeur-form" class="form-panel">
              <label>Full Name<input name="full_name" required /></label>
              <label>Phone<input name="phone" required /></label>
              <label>Email<input name="email" type="email" /></label>
              <label>National ID<input name="national_id" /></label>
              <label>License Number<input name="license_number" /></label>
              <label>License Expiry<input name="license_expiry" type="date" /></label>
              <label>Status
                <select name="status">
                  <option value="available">available</option>
                  <option value="on_trip">on_trip</option>
                  <option value="off_duty">off_duty</option>
                  <option value="inactive">inactive</option>
                </select>
              </label>
              <label>Assigned Vehicle
                <select name="assigned_vehicle_id" id="chauffeur-vehicle-select">
                  <option value="">No vehicle</option>
                </select>
              </label>
              <label>Notes<textarea name="notes" rows="3"></textarea></label>
              <button type="submit">Add Chauffeur</button>
            </form>
          </div>
        </div>
      </div>

      <!-- Vehicle Modal -->
      <div class="admin-modal hidden" id="vehicle-modal" role="dialog" aria-modal="true" aria-labelledby="vehicle-modal-title">
        <div class="admin-modal-backdrop" data-close-modal></div>
        <div class="admin-modal-panel">
          <div class="admin-modal-head">
            <h3 id="vehicle-modal-title">Create Vehicle</h3>
            <button type="button" class="icon-btn" data-close-modal aria-label="Close modal">×</button>
          </div>
          <div class="admin-modal-body">
            <form id="vehicle-form" class="form-panel">
              <label>Name<input name="name" required /></label>
              <label>Model<input name="model" required /></label>
              <label>Category
                <select name="category" required>
                  <option value="economy">economy</option>
                  <option value="business">business</option>
                  <option value="suv">suv</option>
                  <option value="van">van</option>
                </select>
              </label>
              <label>Capacity<input name="capacity" type="number" min="1" max="12" required /></label>
              <label>Base Price (BHD)
                <input name="base_price" type="number" step="0.001" min="0" placeholder="0.000" required class="money-input" />
              </label>
              <p id="vehicle-form-message" style="margin:0;padding-top:6px"></p>
              <label>Features (comma separated)<input name="features" /></label>
              <button type="submit">Add Vehicle</button>
            </form>
          </div>
        </div>
      </div>

      <!-- Promo Modal -->
      <div class="admin-modal hidden" id="promo-modal" role="dialog" aria-modal="true" aria-labelledby="promo-modal-title">
        <div class="admin-modal-backdrop" data-close-modal></div>
        <div class="admin-modal-panel">
          <div class="admin-modal-head">
            <h3 id="promo-modal-title">Create Promotion</h3>
            <button type="button" class="icon-btn" data-close-modal aria-label="Close modal">×</button>
          </div>
          <div class="admin-modal-body">
            <form id="promo-form" class="form-panel">
              <label>Code<input name="code" required /></label>
              <label>Type
                <select name="discount_type">
                  <option value="percent">percent</option>
                  <option value="fixed">fixed</option>
                </select>
              </label>
              <label>Value<input name="discount_value" type="number" step="0.001" required /></label>
              <label>Max Uses<input name="max_uses" type="number" min="1" /></label>
              <label>Expires At<input name="expires_at" type="datetime-local" /></label>
              <label>Min Amount<input name="min_amount" type="number" step="0.001" value="0" /></label>
              <p id="promo-form-message" style="margin:0;padding-top:6px"></p>
              <button type="submit">Add Promo</button>
            </form>
          </div>
        </div>
      </div>

      <!-- User Modal -->
      <div class="admin-modal hidden" id="user-modal" role="dialog" aria-modal="true" aria-labelledby="user-modal-title">
        <div class="admin-modal-backdrop" data-close-modal></div>
        <div class="admin-modal-panel">
          <div class="admin-modal-head">
            <h3 id="user-modal-title">Create User</h3>
            <button type="button" class="icon-btn" data-close-modal aria-label="Close modal">×</button>
          </div>
          <div class="admin-modal-body">
            <form id="user-form" class="form-panel">
              <label>Full Name<input name="full_name" required /></label>
              <label>Email<input name="email" type="email" required /></label>
              <label>Password<input name="password" type="password" required /></label>
              <label>Role
                <select name="role">
                  <option value="operator">operator</option>
                  <option value="admin">admin</option>
                </select>
              </label>
              <button type="submit">Add User</button>
            </form>
          </div>
        </div>
      </div>    </main>
  </div>

  <script src="/js/admin.js?v=20260408" defer></script>
</body>
</html>
